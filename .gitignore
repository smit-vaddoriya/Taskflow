Set-Content .gitignore @"
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Dependencies
node_modules
backend/node_modules

# Build output
dist
dist-ssr
backend/dist
.vite

# Environment variables — NEVER push these
.env
.env.local
.env.production
backend/.env

# Editor
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
Thumbs.db
"@